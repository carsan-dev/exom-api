# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/exom?schema=public

# Firebase
FIREBASE_PROJECT_ID=exom-app
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@exom-app.iam.gserviceaccount.com

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=exom-media
R2_PUBLIC_URL=https://media.exom.app

# Cloudflare Stream
CF_STREAM_API_TOKEN=
CF_STREAM_ACCOUNT_ID=

# App
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
LOGIN_MAX_ATTEMPTS=3
LOGIN_LOCK_DURATION_MINUTES=30
